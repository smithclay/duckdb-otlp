# name: test/sql/read_otlp_metrics_exp_histogram_ndjson.test
# description: verify read_otlp_metrics_exp_histogram with NDJSON (one record per line) input
# group: [sql]

require otlp

# The NDJSON fixture contains the same exponential histogram payload as
# metrics_all_types.jsonl (line 4 of that file) but as a standalone NDJSON
# file. Expected outputs are identical to those in
# read_otlp_metrics_exp_histogram.test.

# Test basic query and row count
query I
SELECT COUNT(*) FROM read_otlp_metrics_exp_histogram('test/data/metrics_exp_histogram_ndjson.jsonl');
----
1

# Test metric name
query I
SELECT name FROM read_otlp_metrics_exp_histogram('test/data/metrics_exp_histogram_ndjson.jsonl');
----
latency.exp

# Test scale value
query I
SELECT scale FROM read_otlp_metrics_exp_histogram('test/data/metrics_exp_histogram_ndjson.jsonl');
----
3

# Test count value
query I
SELECT count FROM read_otlp_metrics_exp_histogram('test/data/metrics_exp_histogram_ndjson.jsonl');
----
12

# Test zero_count value
query I
SELECT zero_count FROM read_otlp_metrics_exp_histogram('test/data/metrics_exp_histogram_ndjson.jsonl');
----
1

# Test sum value
query R
SELECT sum FROM read_otlp_metrics_exp_histogram('test/data/metrics_exp_histogram_ndjson.jsonl');
----
45.5

# Test min/max values
query RR
SELECT min, max FROM read_otlp_metrics_exp_histogram('test/data/metrics_exp_histogram_ndjson.jsonl');
----
1.0	9.5

# Test bucket offsets
query II
SELECT positive_offset, negative_offset FROM read_otlp_metrics_exp_histogram('test/data/metrics_exp_histogram_ndjson.jsonl');
----
2	-1

# Test service_name extraction
query I
SELECT service_name FROM read_otlp_metrics_exp_histogram('test/data/metrics_exp_histogram_ndjson.jsonl');
----
test-service

# Test unit
query I
SELECT unit FROM read_otlp_metrics_exp_histogram('test/data/metrics_exp_histogram_ndjson.jsonl');
----
ms
