###############################################################################
# Required
###############################################################################

# Supported values:
#   local-ducklake       Local DuckLake catalog and local Parquet storage.
#   r2-data-catalog      Cloudflare R2 Data Catalog as an Iceberg REST catalog.
#   s3-tables            Amazon S3 Tables as an Iceberg REST catalog.
#   r2-local-ducklake    Local DuckLake catalog with data files in Cloudflare R2.
#   r2-neon-ducklake     Neon PostgreSQL DuckLake catalog with data files in R2.
#
# Aliases:
#   ducklake-local -> local-ducklake
#   cloudflare     -> r2-data-catalog
#   s3tables       -> s3-tables
DUCKDB_MODE=local-ducklake

###############################################################################
# OTEL Server
###############################################################################

OTEL_HTTP_ADDR=0.0.0.0:4318

# Token required by OTLP/HTTP POSTs. Must be at least 16 characters.
DUCKDB_OTLP_TOKEN=dev-otlp-token-123456

###############################################################################
# DuckDB
###############################################################################

DUCKDB_DATABASE=/data/duckdb-otlp-control.duckdb
DUCKDB_SCHEMA=main

# Print validation results and generated SQL, then exit without starting the
# server. Generated SQL uses getenv(...) for secrets.
DRY_RUN=0

###############################################################################
# local-ducklake / ducklake-local
###############################################################################

# Only used when DUCKDB_MODE=local-ducklake or ducklake-local.
DUCKLAKE_NAME=otel
DUCKLAKE_CATALOG_PATH=/data/ducklake/catalog.duckdb
DUCKLAKE_DATA_PATH=/data/ducklake/storage

###############################################################################
# r2-data-catalog / cloudflare
###############################################################################

# Only used when DUCKDB_MODE=r2-data-catalog or cloudflare.
# CLOUDFLARE_CATALOG_URI is the Catalog URI from `wrangler r2 bucket catalog get`.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_CATALOG_URI=
CLOUDFLARE_CATALOG_TOKEN=

# R2 S3-compatible credentials. These are also accepted as
# R2_ACCESS_KEY_ID/R2_SECRET_ACCESS_KEY or CLOUDFLARE_S3_ACCESS_KEY_ID/
# CLOUDFLARE_S3_SECRET_ACCESS_KEY.
CLOUDFLARE_ACCESS_KEY_ID=
CLOUDFLARE_SECRET_ACCESS_KEY=

###############################################################################
# s3-tables / s3tables
###############################################################################

# Only used when DUCKDB_MODE=s3-tables or s3tables.
AWS_REGION=
AWS_PROFILE=
S3_TABLES_BUCKET_ARN=

###############################################################################
# r2-local-ducklake
###############################################################################

# Only used when DUCKDB_MODE=r2-local-ducklake.
# Reuses CLOUDFLARE_ACCOUNT_ID, CLOUDFLARE_R2_BUCKET,
# CLOUDFLARE_ACCESS_KEY_ID, and CLOUDFLARE_SECRET_ACCESS_KEY above.
CLOUDFLARE_R2_PREFIX=duckdb-otlp/

###############################################################################
# r2-neon-ducklake
###############################################################################

# Only used when DUCKDB_MODE=r2-neon-ducklake.
# Reuses the R2 settings above for DuckLake data files.
NEON_PGHOST=
NEON_PGPORT=5432
NEON_PGDATABASE=
NEON_PGUSER=
NEON_PGPASSWORD=
NEON_PGSSLMODE=require
